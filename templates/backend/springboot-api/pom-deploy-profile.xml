<profiles>
    <profile>
        <id>prod</id>

        <properties>
            <!-- 应用基础信息 -->
            <app.name>xxx-admin-api</app.name>
            <app.profile>prod</app.profile>

            <!-- Maven 构建产物名 -->
            <project.build.finalName>${app.name}</project.build.finalName>

            <!-- SSH 参数 -->
            <deploy.ssh.user>root</deploy.ssh.user>
            <deploy.ssh.host>47.101.xx.xxx</deploy.ssh.host>
            <deploy.ssh.key>${user.home}\.ssh\id_rsa</deploy.ssh.key>

            <!-- 部署目录 -->
            <deploy.root>/opt/${app.name}</deploy.root>

            <!-- 上传目标：统一遵循 APP_NAME-PROFILE.jar -->
            <deploy.remote.tmp>${deploy.root}/tmp/${app.name}-${app.profile}.jar</deploy.remote.tmp>

            <!-- 部署脚本 -->
            <deploy.remote.script>/opt/deploy/deploy-${app.name}-${app.profile}.sh</deploy.remote.script>

            <!-- 可选：部署后检查目录 -->
            <deploy.current.dir>${deploy.root}/current</deploy.current.dir>
        </properties>

        <build>
            <finalName>${app.name}</finalName>

            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-antrun-plugin</artifactId>
                    <version>3.1.0</version>
                    <executions>
                        <execution>
                            <id>deploy-to-${app.profile}</id>
                            <phase>package</phase>
                            <configuration>
                                <target>
                                    <!-- 1) 上传 JAR -->
                                    <echo>==> scp upload: target/${project.build.finalName}.jar -> ${deploy.ssh.user}@${deploy.ssh.host}:${deploy.remote.tmp}</echo>
                                    <exec executable="scp" failonerror="true">
                                        <arg value="-i"/>
                                        <arg value="${deploy.ssh.key}"/>
                                        <arg value="-o"/>
                                        <arg value="BatchMode=yes"/>
                                        <arg value="-o"/>
                                        <arg value="StrictHostKeyChecking=no"/>
                                        <arg value="target/${project.build.finalName}.jar"/>
                                        <arg value="${deploy.ssh.user}@${deploy.ssh.host}:${deploy.remote.tmp}"/>
                                    </exec>

                                    <!-- 2) 执行部署脚本 -->
                                    <echo>==> ssh deploy: ${deploy.remote.script}</echo>
                                    <exec executable="ssh" failonerror="true">
                                        <arg value="-i"/>
                                        <arg value="${deploy.ssh.key}"/>
                                        <arg value="-o"/>
                                        <arg value="BatchMode=yes"/>
                                        <arg value="-o"/>
                                        <arg value="StrictHostKeyChecking=no"/>
                                        <arg value="${deploy.ssh.user}@${deploy.ssh.host}"/>
                                        <arg value="bash ${deploy.remote.script}"/>
                                    </exec>

                                    <!-- 3) 打印 current -->
                                    <echo>==> fetch current release (optional)</echo>
                                    <exec executable="ssh">
                                        <arg value="-i"/>
                                        <arg value="${deploy.ssh.key}"/>
                                        <arg value="-o"/>
                                        <arg value="BatchMode=yes"/>
                                        <arg value="-o"/>
                                        <arg value="StrictHostKeyChecking=no"/>
                                        <arg value="${deploy.ssh.user}@${deploy.ssh.host}"/>
                                        <arg value="ls -l ${deploy.current.dir}"/>
                                    </exec>

                                    <!-- 4) 打印 version.txt -->
                                    <exec executable="ssh">
                                        <arg value="-i"/>
                                        <arg value="${deploy.ssh.key}"/>
                                        <arg value="-o"/>
                                        <arg value="BatchMode=yes"/>
                                        <arg value="-o"/>
                                        <arg value="StrictHostKeyChecking=no"/>
                                        <arg value="${deploy.ssh.user}@${deploy.ssh.host}"/>
                                        <arg value="cat ${deploy.current.dir}/version.txt"/>
                                    </exec>
                                </target>
                            </configuration>
                            <goals>
                                <goal>run</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>
            </plugins>
        </build>
    </profile>
</profiles>